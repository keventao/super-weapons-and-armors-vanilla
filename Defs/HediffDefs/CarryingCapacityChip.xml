<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!-- ==================== Carrying Capacity Chip - Hediff ==================== -->
    <HediffDef ParentName="ImplantHediffBase">
        <defName>MyMod_CarryingCapacityChip</defName>
        <label>Carrying Capacity Chip</label>
        <labelNoun>a Carrying Capacity Chip</labelNoun>
        <description>A neural implant that increases the colonist's carrying capacity, allowing them to haul much heavier loads.</description>
        <descriptionHyperlinks><ThingDef>MyMod_CarryingCapacityChip</ThingDef></descriptionHyperlinks>
        <stages>
            <li>
                <statOffsets>
                    <CarryingCapacity>500</CarryingCapacity>
                </statOffsets>
            </li>
        </stages>
        <spawnThingOnRemoved>MyMod_CarryingCapacityChip</spawnThingOnRemoved>
    </HediffDef>

    <!-- ==================== Carrying Capacity Chip - Item ==================== -->
    <ThingDef ParentName="BodyPartBase">
        <defName>MyMod_CarryingCapacityChip</defName>
        <label>Carrying Capacity Chip</label>
        <description>A neural implant that boosts carrying capacity. Haul everything, everywhere.</description>
        <graphicData>
            <texPath>Things/Item/Health/HealthItem</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <MarketValue>500</MarketValue>
            <WorkToMake>500</WorkToMake>
        </statBases>
        <thingCategories>
            <li>BodyParts</li>
        </thingCategories>
        <techHediffsTags>
            <li>Advanced</li>
        </techHediffsTags>
        <costList>
            <Steel>1</Steel>
        </costList>
        <recipeMaker>
            <workSkill>Crafting</workSkill>
            <skillRequirements>
                <Crafting>0</Crafting>
            </skillRequirements>
            <recipeUsers>
                <li>FabricationBench</li>
                <li>TableMachining</li>
                <li>CraftingSpot</li>
            </recipeUsers>
        </recipeMaker>
    </ThingDef>

    <!-- ==================== Install Recipe ==================== -->
    <RecipeDef>
        <defName>MyMod_InstallCarryingCapacityChip</defName>
        <label>install Carrying Capacity Chip</label>
        <workerClass>Recipe_InstallImplant</workerClass>
        <workAmount>500</workAmount>
        <skillRequirements>
            <Medicine>0</Medicine>
        </skillRequirements>
        <recipeUsers>
            <li>Human</li>
        </recipeUsers>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>MyMod_CarryingCapacityChip</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>MyMod_CarryingCapacityChip</li>
            </thingDefs>
        </fixedIngredientFilter>
        <appliedOnFixedBodyParts>
            <li>Brain</li>
        </appliedOnFixedBodyParts>
        <addsHediff>MyMod_CarryingCapacityChip</addsHediff>
    </RecipeDef>

</Defs>
