<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ==================== 三级头盔 (Tier 3 Helmet) - 原生版 ==================== -->
  <!-- 代码结构对照 LWOP LWApparelArmorHelmetPowerBase，数值保持 CE 版原值 -->

  <ThingDef ParentName="ApparelBase">
    <defName>MyMod_Tier3Helmet_Vanilla</defName>
    <label>Flying Tigers Elite Helmet (Vanilla)</label>
    <description>Elite combat helmet from the Flying Tigers unit. Provides exceptional protection against bullets, blunt attacks, and electrical damage. Enhanced with advanced materials for maximum defense. (Vanilla version)</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PowerArmorHelmet/PowerArmorHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0</generateCommonality>
    <uiIconScale>1.25</uiIconScale>

    <!-- 数值保持 CE 版原值 -->
    <statBases>
      <WorkToMake>1000</WorkToMake>
      <MaxHitPoints>2500</MaxHitPoints>
      <Mass>1</Mass>
      <Flammability>0</Flammability>
      <ArmorRating_Sharp>200</ArmorRating_Sharp>
      <ArmorRating_Blunt>200</ArmorRating_Blunt>
      <ArmorRating_Heat>200</ArmorRating_Heat>
      <Insulation_Cold>200</Insulation_Cold>
      <Insulation_Heat>200</Insulation_Heat>
      <EquipDelay>0</EquipDelay>
    </statBases>

    <!-- 数值保持 CE 版原值 -->
    <equippedStatOffsets>
      <ResearchSpeedFactor>40</ResearchSpeedFactor>
      <GlobalLearningFactor>40</GlobalLearningFactor>
      <HackingSpeed>40</HackingSpeed>
      <PruningSpeed>40</PruningSpeed>
      <NegotiationAbility>10</NegotiationAbility>
      <TradePriceImprovement>10</TradePriceImprovement>
      <SocialImpact>10</SocialImpact>
      <ConversionPower>10</ConversionPower>
      <ArrestSuccessChance>10</ArrestSuccessChance>
      <SuppressionPower>10</SuppressionPower>
      <TameAnimalChance>10</TameAnimalChance>
      <TrainAnimalChance>10</TrainAnimalChance>
      <BondAnimalChanceFactor>10</BondAnimalChanceFactor>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">100</VacuumResistance>
      <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">99</ToxicEnvironmentResistance>
      <PsychicEntropyRecoveryRate MayRequire="Ludeon.RimWorld.Royalty">200</PsychicEntropyRecoveryRate>
      <MeditationFocusGain MayRequire="Ludeon.RimWorld.Royalty">200</MeditationFocusGain>
      <PsychicEntropyGain MayRequire="Ludeon.RimWorld.Royalty">1</PsychicEntropyGain>
      <PsychicEntropyMax MayRequire="Ludeon.RimWorld.Royalty">999</PsychicEntropyMax>
    </equippedStatOffsets>

    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <tradeTags>
      <li>LWHiTechArmor</li>
    </tradeTags>
    <costList>
      <Steel>1</Steel>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <layers>
        <li>Overhead</li>
      </layers>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PowerArmorHelmet/PowerArmorHelmet</wornGraphicPath>
      <tags>
        <li>IndustrialMilitary</li>
      </tags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
    </apparel>

    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
      </options>
    </colorGenerator>

    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>

    <recipeMaker>
      <skillRequirements>
        <Crafting>0</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>FabricationBench</li>
        <li>TableMachining</li>
        <li>CraftingSpot</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>

</Defs>
